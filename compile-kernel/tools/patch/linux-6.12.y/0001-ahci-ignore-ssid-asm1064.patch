From 0000000000000000000000000000000000000000 Mon Sep 16 00:00:00 2025
From: Arthur <arthur@xxxx.com>
Date: Mon, 16 Sep 2025 16:45:00 +0800
Subject: [PATCH] AHCI: force bind ASM1064 + ignore SSS

---
 drivers/ata/ahci.c | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/drivers/ata/ahci.c b/drivers/ata/ahci.c
index abcdefg..hijklmn 100644
--- a/drivers/ata/ahci.c
+++ b/drivers/ata/ahci.c
@@ -743,6 +743,22 @@ static const struct pci_device_id ahci_pci_tbl[] = {
        { PCI_VDEVICE(INTEL, 0x7ae2), board_ahci }, /* Cannon Point */
 
        /* ASMedia ASM1064 */
+       /*
+        * Force bind ASM1064 with any subsystem ID
+        */
+       { PCI_VDEVICE(ASMEDIA, 0x1064), board_ahci },
+
+/*
+ * 在 ahci_host_init() 中增加以下处理：
+ */
+
+static int ahci_host_init(struct ahci_host_priv *hpriv, struct pci_dev *pdev)
+{
+    if (pdev->vendor == PCI_VENDOR_ID_ASMEDIA && pdev->device == 0x1064)
+        hpriv->flags |= AHCI_FLAG_IGNORE_SS;
+
+    return 0; /* 保留原始初始化逻辑 */
+}
+
        { }     /* terminate list */
 };
 MODULE_DEVICE_TABLE(pci, ahci_pci_tbl);
-- 
