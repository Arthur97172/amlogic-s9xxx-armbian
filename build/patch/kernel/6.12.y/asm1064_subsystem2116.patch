Subject: [PATCH] ahci: Add support for ASM1064 subsystem 2116

---
 drivers/ata/ahci.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/ata/ahci.c b/drivers/ata/ahci.c
index abcdef0..1234567 100644
--- a/drivers/ata/ahci.c
+++ b/drivers/ata/ahci.c
@@ -XXX,6 +XXX,7 @@ static const struct pci_device_id ahci_pci_tbl[] = {
     { PCI_VDEVICE(ASMEDIA, 0x1064), board_ahci }, /* ASM1064 */
+    { PCI_DEVICE_SUB(PCI_VENDOR_ID_ASMEDIA, 0x1064, 0x1b21, 0x2116), .driver_data = board_ahci }, /* ASM1064 subsystem 2116 */
